# ============================================================
# FUNCIÓN AUXILIAR PARA RECICLAR EL MODELO DE SOSPECHA
# ============================================================

def run_suspicion_profile_block(
    data,
    block_prefix,
    block_title,
    out_suffix,
    break_date,
    id_col,
    out_dir,
    random_state=42,
    cobertura_objetivo=None
):
    work_df = data.copy()

    if "AGRUPACION_QS" not in work_df.columns:
        raise ValueError("No encuentro AGRUPACION_QS para filtrar Falabella.")

    safe_upper_col(work_df, "AGRUPACION_QS")

    if cobertura_objetivo is not None:
        if "COB" not in work_df.columns:
            raise ValueError("No encuentro COB para aplicar el filtro de cobertura.")
        safe_upper_col(work_df, "COB")
        cobertura_objetivo = cobertura_objetivo.strip().upper()

    # Universo
    mask = (
        (work_df["AGRUPACION_QS"] == "FALABELLA") &
        (work_df["FEC_OCURRENCIA_FINAL"] >= break_date)
    )

    if cobertura_objetivo is not None:
        mask = mask & (work_df["COB"] == cobertura_objetivo)

    work_df = work_df[mask].copy()

    if work_df.empty:
        raise ValueError(f"No hay registros para el universo {block_title}.")

    work_df["y_sus"] = (work_df["SOSPECHA_FINAL"].fillna(0) >= 2).astype(int)

    print_section(f"{block_prefix}) {block_title}")
    print("Shape universo:", work_df.shape)
    print("Tasa sospechosos (y_sus):", round(work_df["y_sus"].mean(), 4))
    display(work_df.head(3))

    # Features derivadas
    work_df = add_suspicion_features(work_df)

    freq_cols_local = [c for c in [
        "COMUNA_PER", "CANAL_VENTA_SEG", "SUCURSAL_VENTA_SEG",
        "MEDIO_PAGO_SEG", "PLAN_AUX", "COB", "GLOSA_GIRO_PER",
        "FRECUENCIA_PAGO"
    ] if c in work_df.columns]

    work_df = add_frequency_features_local(work_df, freq_cols_local)

    print_section(f"{block_prefix}.3) MODELOS SUPERVISADOS DE SOSPECHA")

    y_sus_local = work_df["y_sus"].astype(int)

    sus_old_num_local = [c for c in [
        "DIF_VIGENCIA",
        "COUNT_OF_NUMERO_FINAL",
        "CUENTA_SIN_FAMILIAR_AUX",
        "USO_TOPE"
    ] if c in work_df.columns]

    sus_new_num_local = [c for c in [
        "EDAD_AL_SINIESTRO",
        "N_SEG_12M_PRE_OCURR",
        "N_SIN_OTRAS_COB",
        "MONTO_FINAL_UF",
        "FLAG_FIN_SEMANA",
        "FLAG_MULTI_SEGURO",
        "FLAG_SIN_CRUZADA",
        "FLAG_EVASION_DIF31_45",
        "FLAG_EVASION_TOPE_75_80",
        "FLAG_0_10D",
        "FLAG_11_30D",
        "FLAG_31_45D",
        "FLAG_46_60D",
        "FLAG_0_30D",
        "FLAG_0_45D",
        "FLAG_TOPE_70_79",
        "FLAG_TOPE_80_89",
        "FLAG_TOPE_90P",
        "FLAG_EVASION_SOFT",
        "FLAG_COMPLEJIDAD_OPERATIVA",
        "FLAG_EVASION_Y_COMPLEJIDAD",
        "INTER_DIFXTOPE",
        "INTER_REPEAT_FAM",
        "INTER_MULTI_CROSS"
    ] if c in work_df.columns]

    sus_new_freq_local = [c for c in work_df.columns if c.endswith("__freq_fal_post") or c.endswith("__rare_fal_post")]

    sus_new_cat_local = [c for c in [
        "COMUNA_PER",
        "CANAL_VENTA_SEG",
        "SUCURSAL_VENTA_SEG",
        "MEDIO_PAGO_SEG",
        "FRECUENCIA_PAGO",
        "PLAN_AUX",
        "COB",
        "GLOSA_GIRO_PER",
        "TRAMO_DIF_VIG",
        "TRAMO_USO_TOPE",
        "TRAMO_EDAD",
        "cluster_comuna_sucursal",
        "cluster_comuna_medio",
        "cluster_plan_cob",
        "cluster_canal_pago"
    ] if c in work_df.columns]

    sus_baseline_features_local = sus_old_num_local.copy()
    sus_extended_features_local = sus_old_num_local + sus_new_num_local + sus_new_freq_local + sus_new_cat_local

    print("Features baseline sospecha:", sus_baseline_features_local)
    print("Features extendidas sospecha:", len(sus_extended_features_local))

    X_sus_base_local = work_df[sus_baseline_features_local].copy()
    X_sus_ext_local = work_df[sus_extended_features_local].copy()

    Xs_train_b, Xs_test_b, ys_train_b, ys_test_b = train_test_split(
        X_sus_base_local, y_sus_local, test_size=0.3, random_state=random_state, stratify=y_sus_local
    )

    Xs_train_e, Xs_test_e, ys_train_e, ys_test_e = train_test_split(
        X_sus_ext_local, y_sus_local, test_size=0.3, random_state=random_state, stratify=y_sus_local
    )

    sus_preprocessor_base_local = ColumnTransformer(
        transformers=[
            ("num", Pipeline([("imputer", SimpleImputer(strategy="median"))]), sus_baseline_features_local)
        ],
        remainder="drop"
    )

    sus_model_base_local = HistGradientBoostingClassifier(
        learning_rate=0.03,
        max_iter=500,
        max_depth=6,
        min_samples_leaf=20,
        l2_regularization=1.0,
        random_state=random_state
    )

    clf_sus_base_local = Pipeline([
        ("preprocessor", sus_preprocessor_base_local),
        ("model", sus_model_base_local)
    ])

    sw_sus_base_local = compute_sample_weight(class_weight="balanced", y=ys_train_b)
    clf_sus_base_local.fit(Xs_train_b, ys_train_b, model__sample_weight=sw_sus_base_local)

    pred_sus_base_train_local = clf_sus_base_local.predict_proba(Xs_train_b)[:, 1]
    pred_sus_base_test_local = clf_sus_base_local.predict_proba(Xs_test_b)[:, 1]

    print("\n=== MODELO BASELINE SOSPECHA ===")
    print("AUC train:", round(roc_auc_score(ys_train_b, pred_sus_base_train_local), 4))
    print("AUC test :", round(roc_auc_score(ys_test_b, pred_sus_base_test_local), 4))
    print("PR-AUC train:", round(average_precision_score(ys_train_b, pred_sus_base_train_local), 4))
    print("PR-AUC test :", round(average_precision_score(ys_test_b, pred_sus_base_test_local), 4))

    sus_num_ext_local = sus_old_num_local + sus_new_num_local + sus_new_freq_local
    sus_cat_ext_local = sus_new_cat_local.copy()

    sus_preprocessor_ext_local = ColumnTransformer(
        transformers=[
            ("num", Pipeline([("imputer", SimpleImputer(strategy="median"))]), sus_num_ext_local),
            ("cat", Pipeline([
                ("imputer", SimpleImputer(strategy="constant", fill_value="MISSING")),
                ("encoder", OrdinalEncoder(handle_unknown="use_encoded_value", unknown_value=-1))
            ]), sus_cat_ext_local)
        ],
        remainder="drop"
    )

    sus_model_ext_local = HistGradientBoostingClassifier(
        learning_rate=0.03,
        max_iter=500,
        max_depth=6,
        min_samples_leaf=20,
        l2_regularization=1.0,
        random_state=random_state
    )

    clf_sus_ext_local = Pipeline([
        ("preprocessor", sus_preprocessor_ext_local),
        ("model", sus_model_ext_local)
    ])

    sw_sus_ext_local = compute_sample_weight(class_weight="balanced", y=ys_train_e)
    clf_sus_ext_local.fit(Xs_train_e, ys_train_e, model__sample_weight=sw_sus_ext_local)

    pred_sus_ext_train_local = clf_sus_ext_local.predict_proba(Xs_train_e)[:, 1]
    pred_sus_ext_test_local = clf_sus_ext_local.predict_proba(Xs_test_e)[:, 1]

    print("\n=== MODELO EXTENDIDO SOSPECHA ===")
    print("AUC train:", round(roc_auc_score(ys_train_e, pred_sus_ext_train_local), 4))
    print("AUC test :", round(roc_auc_score(ys_test_e, pred_sus_ext_test_local), 4))
    print("PR-AUC train:", round(average_precision_score(ys_train_e, pred_sus_ext_train_local), 4))
    print("PR-AUC test :", round(average_precision_score(ys_test_e, pred_sus_ext_test_local), 4))

    comparison_sus_local = pd.DataFrame({
        "modelo": ["baseline_sospecha", "extendido_sospecha"],
        "auc_test": [
            roc_auc_score(ys_test_b, pred_sus_base_test_local),
            roc_auc_score(ys_test_e, pred_sus_ext_test_local)
        ],
        "pr_auc_test": [
            average_precision_score(ys_test_b, pred_sus_base_test_local),
            average_precision_score(ys_test_e, pred_sus_ext_test_local)
        ]
    })

    print("\n=== COMPARACIÓN MODELOS SOSPECHA ===")
    display(comparison_sus_local)
    comparison_sus_local.to_csv(os.path.join(out_dir, f"comparison_modelos_sospecha_{out_suffix}.csv"), index=False)

    print_section(f"{block_prefix}.4) IMPORTANCIA DE VARIABLES - SOSPECHA")

    perm_sus_local = permutation_importance(
        clf_sus_ext_local,
        Xs_test_e,
        ys_test_e,
        n_repeats=10,
        random_state=random_state,
        scoring="average_precision"
    )

    perm_sus_df_local = pd.DataFrame({
        "feature": sus_extended_features_local,
        "importance_mean": perm_sus_local.importances_mean,
        "importance_std": perm_sus_local.importances_std
    }).sort_values("importance_mean", ascending=False)

    display(perm_sus_df_local.head(30))
    perm_sus_df_local.to_csv(os.path.join(out_dir, f"permutation_importance_sospecha_{out_suffix}.csv"), index=False)

    nuevas_vs_historicas_local = perm_sus_df_local[
        ~perm_sus_df_local["feature"].isin(sus_old_num_local)
    ].copy()

    print("\n=== VARIABLES NUEVAS MÁS IMPORTANTES PARA SOSPECHA ===")
    display(nuevas_vs_historicas_local.head(20))
    nuevas_vs_historicas_local.to_csv(os.path.join(out_dir, f"variables_nuevas_sospecha_{out_suffix}.csv"), index=False)

    plt.figure(figsize=(10, 7))
    sns.barplot(data=nuevas_vs_historicas_local.head(15), y="feature", x="importance_mean")
    plt.title(f"Variables nuevas más importantes para explicar sospecha - {block_title}")
    plt.xlabel("Permutation importance (mean)")
    plt.ylabel("Variable")
    plt.tight_layout()
    plt.show()

    work_df["risk_sus_base"] = clf_sus_base_local.predict_proba(X_sus_base_local)[:, 1]
    work_df["risk_sus_ext"] = clf_sus_ext_local.predict_proba(X_sus_ext_local)[:, 1]
    work_df["delta_sus"] = work_df["risk_sus_ext"] - work_df["risk_sus_base"]

    print("\nDistribución delta_sus:")
    display(work_df["delta_sus"].describe())

    print_section(f"{block_prefix}.6) LIFT TABLES POR SEGMENTO")

    review_sus_cols_local = [c for c in [
        "COMUNA_PER",
        "CANAL_VENTA_SEG",
        "SUCURSAL_VENTA_SEG",
        "MEDIO_PAGO_SEG",
        "PLAN_AUX",
        "COB",
        "GLOSA_GIRO_PER",
        "TRAMO_DIF_VIG",
        "TRAMO_USO_TOPE",
        "TRAMO_EDAD",
        "cluster_comuna_sucursal",
        "cluster_comuna_medio",
        "cluster_plan_cob",
        "cluster_canal_pago"
    ] if c in work_df.columns]

    for col in review_sus_cols_local:
        print(f"\n=== LIFT TABLE: {col} ===")
        tmp_table = suspicion_shift_table(work_df, col, id_col_=id_col, min_size=20, top_n=20)
        display(tmp_table)
        tmp_table.to_csv(os.path.join(out_dir, f"sus_shift_{col}_{out_suffix}.csv"), index=False)

    print_section(f"{block_prefix}.7) ISOLATION FOREST - SOSPECHA / RAREZA INTERNA")

    iso_sus_num_local = [c for c in [
        "DIF_VIGENCIA", "COUNT_OF_NUMERO_FINAL", "CUENTA_SIN_FAMILIAR_AUX", "USO_TOPE",
        "EDAD_AL_SINIESTRO", "N_SEG_12M_PRE_OCURR", "N_SIN_OTRAS_COB", "MONTO_FINAL_UF",
        "FLAG_FIN_SEMANA", "FLAG_MULTI_SEGURO", "FLAG_SIN_CRUZADA",
        "FLAG_EVASION_DIF31_45", "FLAG_EVASION_TOPE_75_80",
        "FLAG_0_10D", "FLAG_31_45D", "FLAG_TOPE_70_79", "FLAG_EVASION_Y_COMPLEJIDAD",
        "INTER_DIFXTOPE", "INTER_REPEAT_FAM", "INTER_MULTI_CROSS"
    ] if c in work_df.columns]

    iso_sus_cat_local = [c for c in [
        "COMUNA_PER", "CANAL_VENTA_SEG", "SUCURSAL_VENTA_SEG", "MEDIO_PAGO_SEG",
        "PLAN_AUX", "COB", "GLOSA_GIRO_PER",
        "cluster_comuna_sucursal", "cluster_plan_cob", "cluster_canal_pago"
    ] if c in work_df.columns]

    X_if_sus_local = build_if_matrix(work_df, work_df, iso_sus_num_local, iso_sus_cat_local)
    scaler_sus_local = StandardScaler()
    X_if_sus_scaled_local = scaler_sus_local.fit_transform(X_if_sus_local)

    iso_sus_local = IsolationForest(
        n_estimators=400,
        contamination="auto",
        random_state=random_state,
        n_jobs=-1
    )
    iso_sus_local.fit(X_if_sus_scaled_local)

    work_df["risk_iso_sus"] = -iso_sus_local.score_samples(X_if_sus_scaled_local)
    iso_sus_threshold_local = work_df["risk_iso_sus"].quantile(0.95)
    work_df["flag_anom_sus"] = (work_df["risk_iso_sus"] >= iso_sus_threshold_local).astype(int)

    print("Threshold anomalía interna:", round(iso_sus_threshold_local, 4))
    print("Anomaly rate:", round(work_df["flag_anom_sus"].mean(), 4))

    print_section(f"{block_prefix}.8) TOP CASOS SOSPECHOSOS")

    work_df["risk_sus_ext_z"] = zscore(work_df["risk_sus_ext"])
    work_df["delta_sus_z"] = zscore(work_df["delta_sus"])
    work_df["risk_iso_sus_z"] = zscore(work_df["risk_iso_sus"])

    work_df["score_sospecha_final"] = (
        0.55 * work_df["risk_sus_ext_z"] +
        0.25 * work_df["delta_sus_z"] +
        0.20 * work_df["risk_iso_sus_z"]
    )

    cols_sus_review_local = [c for c in [
        id_col,
        "FEC_OCURRENCIA_FINAL",
        "RUT_JOIN",
        "POLIZA_JOIN",
        "COMUNA_PER",
        "CANAL_VENTA_SEG",
        "SUCURSAL_VENTA_SEG",
        "MEDIO_PAGO_SEG",
        "PLAN_AUX",
        "COB",
        "GLOSA_GIRO_PER",
        "DIF_VIGENCIA",
        "USO_TOPE",
        "COUNT_OF_NUMERO_FINAL",
        "CUENTA_SIN_FAMILIAR_AUX",
        "N_SEG_12M_PRE_OCURR",
        "N_SIN_OTRAS_COB",
        "FLAG_EVASION_DIF31_45",
        "FLAG_EVASION_TOPE_75_80",
        "FLAG_MULTI_SEGURO",
        "FLAG_SIN_CRUZADA",
        "FLAG_EVASION_Y_COMPLEJIDAD",
        "risk_sus_base",
        "risk_sus_ext",
        "delta_sus",
        "risk_iso_sus",
        "score_sospecha_final",
        "y_sus"
    ] if c in work_df.columns]

    top_sus_local = work_df.sort_values("score_sospecha_final", ascending=False)[cols_sus_review_local].head(300)
    display(top_sus_local.head(20))
    top_sus_local.to_csv(os.path.join(out_dir, f"top300_sospechosos_{out_suffix}.csv"), index=False)

    print_section(f"{block_prefix}.9) PERFIL PROMEDIO: SOSPECHOSOS VS NO SOSPECHOSOS")

    compare_cols_sus_local = [c for c in [
        "DIF_VIGENCIA", "USO_TOPE", "COUNT_OF_NUMERO_FINAL", "CUENTA_SIN_FAMILIAR_AUX",
        "N_SEG_12M_PRE_OCURR", "N_SIN_OTRAS_COB", "MONTO_FINAL_UF", "EDAD_AL_SINIESTRO",
        "FLAG_0_10D", "FLAG_31_45D", "FLAG_TOPE_70_79",
        "FLAG_MULTI_SEGURO", "FLAG_SIN_CRUZADA", "FLAG_EVASION_Y_COMPLEJIDAD",
        "INTER_DIFXTOPE", "INTER_REPEAT_FAM", "INTER_MULTI_CROSS"
    ] if c in work_df.columns]

    profile_sus_local = work_df.groupby("y_sus")[compare_cols_sus_local].mean().T
    profile_sus_local.columns = ["NO_SOSPECHOSO", "SOSPECHOSO"]
    profile_sus_local["DIFF_SOS_MINUS_NO"] = profile_sus_local["SOSPECHOSO"] - profile_sus_local["NO_SOSPECHOSO"]

    display(profile_sus_local.sort_values("DIFF_SOS_MINUS_NO", ascending=False))
    profile_sus_local.to_csv(os.path.join(out_dir, f"perfil_sospechosos_vs_no_{out_suffix}.csv"))

    return {
        "data": work_df,
        "clf_base": clf_sus_base_local,
        "clf_ext": clf_sus_ext_local,
        "sus_extended_features": sus_extended_features_local,
        "freq_cols": freq_cols_local
    }






