]
for c in cat_like_cols:
    safe_upper_col(df, c)

# Deduplicación
before = len(df)
df = df.drop_duplicates(subset=[id_col]).copy()
print("Filas antes:", before)
print("Filas después:", len(df))

# Auxiliares
df["y_rule"] = (df["SOSPECHA_FINAL"].fillna(0) >= 2).astype(int)
