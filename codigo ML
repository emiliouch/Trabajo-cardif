def suspicion_shift_table(data, col, id_col_, min_size=20, top_n=20):
    tmp = data[data[col].notna() & (data[col] != "")].copy()
    if tmp.empty:
        return pd.DataFrame(columns=[col, "n_total", "n_sus", "sus_rate", "avg_risk_sus", "avg_delta_sus", "lift_vs_avg"])
    g = tmp.groupby(col).agg(
        n_total=(id_col_, "count"),
        n_sus=("y_sus", "sum"),
        sus_rate=("y_sus", "mean"),
        avg_risk_sus=("risk_sus_ext", "mean"),
        avg_delta_sus=("delta_sus", "mean")
    ).reset_index()
    g = g[g["n_total"] >= min_size].copy()
    overall = tmp["y_sus"].mean()
    g["lift_vs_avg"] = g["sus_rate"] / overall if overall > 0 else np.nan
    return g.sort_values(["lift_vs_avg", "n_sus"], ascending=[False, False]).head(top_n)

