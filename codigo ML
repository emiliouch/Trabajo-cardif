            out["COUNT_OF_NUMERO_FINAL"].fillna(0) * out["CUENTA_SIN_FAMILIAR_AUX"].fillna(0)
        )

    if {"N_SEG_12M_PRE_OCURR", "N_SIN_OTRAS_COB"}.issubset(out.columns):
        out["INTER_MULTI_CROSS"] = (
            out["N_SEG_12M_PRE_OCURR"].fillna(0) * out["N_SIN_OTRAS_COB"].fillna(0)
        )

    # 2) Buckets DIF_VIGENCIA
    if "DIF_VIGENCIA" in out.columns:
        out["FLAG_0_10D"] = ((out["DIF_VIGENCIA"] >= 0) & (out["DIF_VIGENCIA"] <= 10)).astype(int)
        out["FLAG_11_30D"] = ((out["DIF_VIGENCIA"] >= 11) & (out["DIF_VIGENCIA"] <= 30)).astype(int)
        out["FLAG_31_45D"] = ((out["DIF_VIGENCIA"] >= 31) & (out["DIF_VIGENCIA"] <= 45)).astype(int)
        out["FLAG_46_60D"] = ((out["DIF_VIGENCIA"] >= 46) & (out["DIF_VIGENCIA"] <= 60)).astype(int)
        out["FLAG_0_30D"] = ((out["DIF_VIGENCIA"] >= 0) & (out["DIF_VIGENCIA"] <= 30)).astype(int)
        out["FLAG_0_45D"] = ((out["DIF_VIGENCIA"] >= 0) & (out["DIF_VIGENCIA"] <= 45)).astype(int)

    # 3) Buckets USO_TOPE
    if "USO_TOPE" in out.columns:
        out["FLAG_TOPE_70_79"] = ((out["USO_TOPE"] >= 0.70) & (out["USO_TOPE"] < 0.80)).astype(int)
        out["FLAG_TOPE_80_89"] = ((out["USO_TOPE"] >= 0.80) & (out["USO_TOPE"] < 0.90)).astype(int)
        out["FLAG_TOPE_90P"] = (out["USO_TOPE"] >= 0.90).astype(int)

    # 4) Flags base
    for c in [
        "FLAG_EVASION_DIF31_45", "FLAG_EVASION_TOPE_75_80",
        "FLAG_MULTI_SEGURO", "FLAG_SIN_CRUZADA"
    ]:
        if c in out.columns:
            out[c] = pd.to_numeric(out[c], errors="coerce").fillna(0).astype(int)

    if {"FLAG_EVASION_DIF31_45", "FLAG_EVASION_TOPE_75_80"}.issubset(out.columns):
        out["FLAG_EVASION_SOFT"] = (
            (out["FLAG_EVASION_DIF31_45"] == 1) |
            (out["FLAG_EVASION_TOPE_75_80"] == 1)
        ).astype(int)

    if {"FLAG_MULTI_SEGURO", "FLAG_SIN_CRUZADA"}.issubset(out.columns):
        out["FLAG_COMPLEJIDAD_OPERATIVA"] = (
            (out["FLAG_MULTI_SEGURO"] == 1) |
            (out["FLAG_SIN_CRUZADA"] == 1)
        ).astype(int)

    if {"FLAG_EVASION_SOFT", "FLAG_COMPLEJIDAD_OPERATIVA"}.issubset(out.columns):
        out["FLAG_EVASION_Y_COMPLEJIDAD"] = (
            (out["FLAG_EVASION_SOFT"] == 1) &
            (out["FLAG_COMPLEJIDAD_OPERATIVA"] == 1)
        ).astype(int)

    # 5) Clusters
    if {"COMUNA_PER", "SUCURSAL_VENTA_SEG"}.issubset(out.columns):
        out["cluster_comuna_sucursal"] = out["COMUNA_PER"] + "|" + out["SUCURSAL_VENTA_SEG"]

    if {"COMUNA_PER", "MEDIO_PAGO_SEG"}.issubset(out.columns):
        out["cluster_comuna_medio"] = out["COMUNA_PER"] + "|" + out["MEDIO_PAGO_SEG"]

    if {"PLAN_AUX", "COB"}.issubset(out.columns):
        out["cluster_plan_cob"] = out["PLAN_AUX"] + "|" + out["COB"]

    if {"CANAL_VENTA_SEG", "MEDIO_PAGO_SEG"}.issubset(out.columns):
        out["cluster_canal_pago"] = out["CANAL_VENTA_SEG"] + "|" + out["MEDIO_PAGO_SEG"]

    return out
