# 11.3 Backtesting temporal
# ============================================================
print_section("11.3) BACKTESTING TEMPORAL")

bt_df = prod_df.copy()
bt_months = sorted(bt_df["year_month"].dropna().unique())

if len(bt_months) < 6:
    print("Muy pocos meses para backtesting robusto. Se omite.")
    backtest_df = pd.DataFrame()
else:
    backtest_rows = []

    # usamos ventanas crecientes:
    # entrenar hasta t-1 y probar en t
    # partimos desde el mes 4 para que haya historia mínima
    for i in range(4, len(bt_months)):
        test_month = bt_months[i]
        train_months_bt = bt_months[:i]

        train_bt = bt_df[bt_df["year_month"].isin(train_months_bt)].copy()
        test_bt = bt_df[bt_df["year_month"] == test_month].copy()

        if train_bt["y_prod"].nunique() < 2:
            continue
        if test_bt["y_prod"].nunique() < 2:
            continue
        if len(test_bt) < 10:
            continue

        X_train_bt = train_bt[reduced_features].copy()
        y_train_bt = train_bt["y_prod"].astype(int)

        X_test_bt = test_bt[reduced_features].copy()
        y_test_bt = test_bt["y_prod"].astype(int)

        bt_model = Pipeline([
            ("preprocessor", reduced_preprocessor),
            ("model", HistGradientBoostingClassifier(
                learning_rate=0.03,
                max_iter=200,
                max_depth=3,
                min_samples_leaf=60,
                l2_regularization=3.0,
                random_state=RANDOM_STATE
            ))
        ])

        sw_bt = compute_sample_weight(class_weight="balanced", y=y_train_bt)
        bt_model.fit(X_train_bt, y_train_bt, model__sample_weight=sw_bt)

        pred_bt = bt_model.predict_proba(X_test_bt)[:, 1]

        row = {
            "test_month": test_month,
            "n_test": len(test_bt),
            "tasa_sospecha_test": y_test_bt.mean(),
            "auc_test": roc_auc_score(y_test_bt, pred_bt),
            "pr_auc_test": average_precision_score(y_test_bt, pred_bt)
        }

        for frac in [0.05, 0.10, 0.20]:
            k_n = max(1, int(len(test_bt) * frac))
            row[f"precision_top_{int(frac*100)}pct"] = precision_at_k(
                y_test_bt.reset_index(drop=True),
                pd.Series(pred_bt),
                k_n
            )

        backtest_rows.append(row)

    backtest_df = pd.DataFrame(backtest_rows)

    display(backtest_df)
    backtest_df.to_csv(os.path.join(OUT_DIR, "backtesting_temporal_modelo_reducido.csv"), index=False)

    if not backtest_df.empty:
        plt.figure(figsize=(10, 5))
        plt.plot(backtest_df["test_month"], backtest_df["pr_auc_test"], marker="o", label="PR-AUC")
        plt.plot(backtest_df["test_month"], backtest_df["auc_test"], marker="o", label="AUC")
        plt.xticks(rotation=45)
        plt.title("Backtesting temporal - modelo reducido")
        plt.xlabel("Mes test")
        plt.ylabel("Métrica")
        plt.legend()
        plt.tight_layout()
        plt.show()

