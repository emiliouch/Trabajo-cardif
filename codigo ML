    prefix=glm_cat_features,
    drop_first=True,
    dtype=float
)

# alinear columnas
X_test_cat = X_test_cat.reindex(columns=X_train_cat.columns, fill_value=0.0)

# concatenar
X_train_glm = pd.concat([X_train_num, X_train_cat], axis=1)
X_test_glm = pd.concat([X_test_num, X_test_cat], axis=1)

# forzar numérico float
X_train_glm = X_train_glm.apply(pd.to_numeric, errors="coerce").astype(float)
X_test_glm = X_test_glm.apply(pd.to_numeric, errors="coerce").astype(float)

# imputación final por si algo quedó NaN
train_medians_final = X_train_glm.median()
X_train_glm = X_train_glm.fillna(train_medians_final)
X_test_glm = X_test_glm.fillna(train_medians_final)

