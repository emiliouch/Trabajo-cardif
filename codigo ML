print_section("11.1) BENCHMARK SCORE VS REGLAS SIMPLES")

# Usamos el mismo universo productivo del bloque 10
bench_df = prod_df.copy()

# test set del split temporal del bloque 10
bench_test = bench_df.loc[test_mask].copy()

if bench_test.empty:
    raise ValueError("bench_test está vacío. Revisa el split temporal del bloque 10.")

# Scores simples / reglas simples
# La idea es comparar si el score productivo realmente agrega valor
# por sobre una priorización fácil de implementar.

bench_test["score_rule_difvig"] = -pd.to_numeric(bench_test["DIF_VIGENCIA"], errors="coerce").fillna(999999)
bench_test["score_rule_uso_tope"] = pd.to_numeric(bench_test["USO_TOPE"], errors="coerce").fillna(-999999)

# Score combinado simple: zscore de DIF_VIGENCIA invertido + USO_TOPE
bench_test["difvig_inv_z"] = zscore(-pd.to_numeric(bench_test["DIF_VIGENCIA"], errors="coerce").fillna(999999))
bench_test["uso_tope_z"] = zscore(pd.to_numeric(bench_test["USO_TOPE"], errors="coerce").fillna(0))
bench_test["score_rule_combo"] = 0.7 * bench_test["difvig_inv_z"] + 0.3 * bench_test["uso_tope_z"]

# Score productivo ya calculado
if "score_prod" not in bench_test.columns:
    raise ValueError("No existe score_prod en bench_test. Revisa que el bloque 10 haya corrido completo.")

benchmark_results = []

benchmark_dict = {
    "modelo_productivo": bench_test["score_prod"],
    "regla_dif_vigencia": bench_test["score_rule_difvig"],
    "regla_uso_tope": bench_test["score_rule_uso_tope"],
    "regla_combo_difvig_uso_tope": bench_test["score_rule_combo"]
}

for name, scores in benchmark_dict.items():
    auc_val = roc_auc_score(bench_test["y_prod"], scores)
    prauc_val = average_precision_score(bench_test["y_prod"], scores)

    row = {
        "modelo": name,
        "auc_test": auc_val,
        "pr_auc_test": prauc_val
    }

    for frac in [0.01, 0.03, 0.05, 0.10, 0.20]:
        k_n = max(1, int(len(bench_test) * frac))
        row[f"precision_top_{int(frac*100)}pct"] = precision_at_k(
            bench_test["y_prod"].reset_index(drop=True),
            pd.Series(scores).reset_index(drop=True),
            k_n
        )

    benchmark_results.append(row)

benchmark_df = pd.DataFrame(benchmark_results).sort_values(["pr_auc_test", "auc_test"], ascending=False)

display(benchmark_df)
benchmark_df.to_csv(os.path.join(OUT_DIR, "benchmark_modelo_vs_reglas_simples.csv"), index=False)

