post_candidates = df[df["is_post"] == 1].copy()
post_candidates["risk_break_ext_z"] = zscore(post_candidates["risk_break_ext"])
post_candidates["delta_break_z"] = zscore(post_candidates["delta_break"])
post_candidates["risk_iso_break_z"] = zscore(post_candidates["risk_iso_break"])

