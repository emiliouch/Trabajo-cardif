        plt.tight_layout()
        plt.show()

# -----------------------------
# 4) Modelaje del quiebre
# -----------------------------
print_section("4) MODELAJE DEL QUIEBRE")

# 4.1 Features
old_num_features = [c for c in [
    "DIF_VIGENCIA",
    "COUNT_OF_NUMERO_FINAL",
    "CUENTA_SIN_FAMILIAR_AUX",
    "USO_TOPE"
] if c in df.columns]

new_num_features = [c for c in [
    "EDAD_AL_SINIESTRO",
    "N_SEG_12M_PRE_OCURR",
    "N_SIN_OTRAS_COB",
    "MONTO_FINAL_UF",
    "FLAG_FIN_SEMANA",
    "FLAG_MULTI_SEGURO",
    "FLAG_SIN_CRUZADA",
    "FLAG_EVASION_DIF31_45",
    "FLAG_EVASION_TOPE_75_80"
] if c in df.columns]

new_cat_features = [c for c in [
    "COMUNA_PER",
    "CANAL_VENTA_SEG",
    "SUCURSAL_VENTA_SEG",
    "MEDIO_PAGO_SEG",
    "FRECUENCIA_PAGO",
    "PLAN_AUX",
    "COB",
    "AGRUPACION_QS",
    "GLOSA_GIRO_PER",
    "TRAMO_EDAD"
] if c in df.columns]

baseline_features = old_num_features.copy()
extended_features = old_num_features + new_num_features + new_cat_features

print("Variables históricas:", baseline_features)
print("Variables nuevas:", [c for c in extended_features if c not in old_num_features])

# 4.2 Split estratificado (target = is_post)
y_break = df["is_post"].astype(int)
X_break_base = df[baseline_features].copy()
X_break_ext = df[extended_features].copy()

Xb_train, Xb_test, yb_train, yb_test = train_test_split(
    X_break_base, y_break, test_size=0.3, random_state=RANDOM_STATE, stratify=y_break
)
Xe_train, Xe_test, ye_train, ye_test = train_test_split(
    X_break_ext, y_break, test_size=0.3, random_state=RANDOM_STATE, stratify=y_break
)

print("Pre total:", int((y_break == 0).sum()), "Post total:", int((y_break == 1).sum()))
print("Train size:", len(yb_train), "Test size:", len(yb_test))

# 4.3 Baseline del quiebre (solo variables históricas)
baseline_preprocessor = ColumnTransformer(
    transformers=[("num", Pipeline([("imputer", SimpleImputer(strategy="median"))]), baseline_features)],
    remainder="drop"
)

baseline_model = HistGradientBoostingClassifier(
    learning_rate=0.03,
    max_iter=500,
    max_depth=6,
    min_samples_leaf=30,
    l2_regularization=1.0,
    random_state=RANDOM_STATE
)

clf_break_base = Pipeline([
    ("preprocessor", baseline_preprocessor),
    ("model", baseline_model)
])

sample_weight_base = compute_sample_weight(class_weight="balanced", y=yb_train)
clf_break_base.fit(Xb_train, yb_train, model__sample_weight=sample_weight_base)

pred_base_train = clf_break_base.predict_proba(Xb_train)[:, 1]
pred_base_test = clf_break_base.predict_proba(Xb_test)[:, 1]

print("\n=== MODELO BASELINE DEL QUIEBRE ===")
print("AUC train:", round(roc_auc_score(yb_train, pred_base_train), 4))
print("AUC test :", round(roc_auc_score(yb_test, pred_base_test), 4))
print("PR-AUC train:", round(average_precision_score(yb_train, pred_base_train), 4))
print("PR-AUC test :", round(average_precision_score(yb_test, pred_base_test), 4))

# 4.4 Modelo extendido del quiebre (históricas + nuevas)
extended_num_features = old_num_features + new_num_features
extended_cat_features = new_cat_features.copy()

extended_preprocessor = ColumnTransformer(
    transformers=[
        ("num", Pipeline([("imputer", SimpleImputer(strategy="median"))]), extended_num_features),
        ("cat", Pipeline([
            ("imputer", SimpleImputer(strategy="constant", fill_value="MISSING")),
            ("encoder", OrdinalEncoder(handle_unknown="use_encoded_value", unknown_value=-1))
        ]), extended_cat_features)
    ],
    remainder="drop"
)

extended_model = HistGradientBoostingClassifier(
    learning_rate=0.03,
    max_iter=500,
    max_depth=6,
    min_samples_leaf=30,
    l2_regularization=1.0,
    random_state=RANDOM_STATE
)

clf_break_ext = Pipeline([
    ("preprocessor", extended_preprocessor),
    ("model", extended_model)
])

sample_weight_ext = compute_sample_weight(class_weight="balanced", y=ye_train)
clf_break_ext.fit(Xe_train, ye_train, model__sample_weight=sample_weight_ext)

pred_ext_train = clf_break_ext.predict_proba(Xe_train)[:, 1]
pred_ext_test = clf_break_ext.predict_proba(Xe_test)[:, 1]

print("\n=== MODELO EXTENDIDO DEL QUIEBRE ===")
print("AUC train:", round(roc_auc_score(ye_train, pred_ext_train), 4))
print("AUC test :", round(roc_auc_score(ye_test, pred_ext_test), 4))
print("PR-AUC train:", round(average_precision_score(ye_train, pred_ext_train), 4))
print("PR-AUC test :", round(average_precision_score(ye_test, pred_ext_test), 4))

comparison_df = pd.DataFrame({
    "modelo": ["baseline_historico", "extendido_nuevas_vars"],
    "auc_test": [
        roc_auc_score(yb_test, pred_base_test),
        roc_auc_score(ye_test, pred_ext_test)
    ],
    "pr_auc_test": [
        average_precision_score(yb_test, pred_base_test),
        average_precision_score(ye_test, pred_ext_test)
    ]
})
print("\n=== COMPARACIÓN DE MODELOS DEL QUIEBRE ===")
display(comparison_df)
comparison_df.to_csv(os.path.join(OUT_DIR, "comparison_modelos_quiebre.csv"), index=False)

# 4.5 Importancia de variables del modelo extendido
perm_break = permutation_importance(
    clf_break_ext,
    Xe_test,
    ye_test,
    n_repeats=10,
    random_state=RANDOM_STATE,
    scoring="average_precision"
)

perm_break_df = pd.DataFrame({
    "feature": extended_features,
    "importance_mean": perm_break.importances_mean,
    "importance_std": perm_break.importances_std
}).sort_values("importance_mean", ascending=False)

print("\n=== IMPORTANCIA DE VARIABLES - MODELO DEL QUIEBRE ===")
display(perm_break_df.head(25))
perm_break_df.to_csv(os.path.join(OUT_DIR, "permutation_importance_quiebre.csv"), index=False)

new_signal_df = perm_break_df[~perm_break_df["feature"].isin(old_num_features)].copy()
print("\n=== VARIABLES NUEVAS QUE MÁS EXPLICAN EL QUIEBRE ===")
display(new_signal_df.head(20))
new_signal_df.to_csv(os.path.join(OUT_DIR, "variables_nuevas_quiebre.csv"), index=False)

top_new_signal = new_signal_df.head(15)
if not top_new_signal.empty:
    plt.figure(figsize=(10, 7))
    sns.barplot(data=top_new_signal, y="feature", x="importance_mean")
    plt.title("Variables nuevas más importantes para explicar el quiebre")
    plt.xlabel("Permutation importance (mean)")
    plt.ylabel("Variable")
    plt.tight_layout()
    plt.show()

# 4.6 Scores del quiebre sobre toda la base
df["risk_break_base"] = clf_break_base.predict_proba(X_break_base)[:, 1]
df["risk_break_ext"] = clf_break_ext.predict_proba(X_break_ext)[:, 1]
df["delta_break"] = df["risk_break_ext"] - df["risk_break_base"]

print("\nDistribución de delta_break:")
display(df["delta_break"].describe())

# 4.7 Tablas por categorías para entender el quiebre
vars_to_review = [c for c in [
    "COMUNA_PER",
    "CANAL_VENTA_SEG",
    "SUCURSAL_VENTA_SEG",
    "MEDIO_PAGO_SEG",
    "PLAN_AUX",
    "COB",
    "AGRUPACION_QS",
    "GLOSA_GIRO_PER"
] if c in df.columns]

shift_tables = {}
for col in vars_to_review:
    print(f"\n=== SHIFT TABLE: {col} ===")
    shift_tables[col] = shift_table(df, col, id_col_=id_col, min_size=20, top_n=20)
    display(shift_tables[col])
    shift_tables[col].to_csv(os.path.join(OUT_DIR, f"shift_{col}.csv"), index=False)

# -----------------------------
# 5) Isolation Forest reorientado al quiebre
# -----------------------------
print_section("5) ISOLATION FOREST DEL QUIEBRE")

pre_df = df[df["is_post"] == 0].copy()
post_df = df[df["is_post"] == 1].copy()

iso_num_features = [c for c in [
    "DIF_VIGENCIA",
    "COUNT_OF_NUMERO_FINAL",
    "CUENTA_SIN_FAMILIAR_AUX",
    "USO_TOPE",
    "EDAD_AL_SINIESTRO",
    "N_SEG_12M_PRE_OCURR",
    "N_SIN_OTRAS_COB",
    "MONTO_FINAL_UF",
    "FLAG_FIN_SEMANA",
    "FLAG_MULTI_SEGURO",
    "FLAG_SIN_CRUZADA",
    "FLAG_EVASION_DIF31_45",
    "FLAG_EVASION_TOPE_75_80"
] if c in df.columns]

iso_cat_features = [c for c in [
    "COMUNA_PER",
    "CANAL_VENTA_SEG",
    "SUCURSAL_VENTA_SEG",
    "MEDIO_PAGO_SEG",
    "PLAN_AUX",
    "COB",
    "AGRUPACION_QS",
    "GLOSA_GIRO_PER"
] if c in df.columns]

X_pre_if = build_if_matrix(pre_df, pre_df, iso_num_features, iso_cat_features)
X_post_if = build_if_matrix(pre_df, post_df, iso_num_features, iso_cat_features)
X_all_if = build_if_matrix(pre_df, df, iso_num_features, iso_cat_features)

scaler_if = StandardScaler()
X_pre_if_s = scaler_if.fit_transform(X_pre_if)
X_post_if_s = scaler_if.transform(X_post_if)
X_all_if_s = scaler_if.transform(X_all_if)

iso_break = IsolationForest(
    n_estimators=400,
    contamination="auto",
    random_state=RANDOM_STATE,
    n_jobs=-1
)
iso_break.fit(X_pre_if_s)

pre_df["risk_iso_break"] = -iso_break.score_samples(X_pre_if_s)
post_df["risk_iso_break"] = -iso_break.score_samples(X_post_if_s)
df["risk_iso_break"] = -iso_break.score_samples(X_all_if_s)

print("Risk mean PRE :", round(pre_df["risk_iso_break"].mean(), 4))
print("Risk mean POST:", round(post_df["risk_iso_break"].mean(), 4))

iso_threshold = pre_df["risk_iso_break"].quantile(0.95)
df["flag_anom_break"] = (df["risk_iso_break"] >= iso_threshold).astype(int)

anom_pre = (pre_df["risk_iso_break"] >= iso_threshold).mean()
anom_post = (post_df["risk_iso_break"] >= iso_threshold).mean()

print("Threshold anomalía (p95 PRE):", round(iso_threshold, 4))
print("Anomaly rate PRE :", round(anom_pre, 4))
print("Anomaly rate POST:", round(anom_post, 4))

