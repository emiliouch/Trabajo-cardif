    ]:
        if c in out.columns:
            safe_upper_col(out, c)

    # 1) Interacciones
    if {"DIF_VIGENCIA", "USO_TOPE"}.issubset(out.columns):
        out["INTER_DIFXTOPE"] = out["DIF_VIGENCIA"] * out["USO_TOPE"]

    if {"COUNT_OF_NUMERO_FINAL", "CUENTA_SIN_FAMILIAR_AUX"}.issubset(out.columns):
