if {"DIF_VIGENCIA", "USO_TOPE"}.issubset(glm_train_prep.columns):
    glm_train_prep["INTER_DIFXTOPE_GLM"] = glm_train_prep["DIF_VIGENCIA"] * glm_train_prep["USO_TOPE"]
    glm_test_prep["INTER_DIFXTOPE_GLM"] = glm_test_prep["DIF_VIGENCIA"] * glm_test_prep["USO_TOPE"]
    glm_num_features_glm = glm_num_features_glm + ["INTER_DIFXTOPE_GLM"]

# numéricas
X_train_num = glm_train_prep[glm_num_features_glm].copy()
X_test_num = glm_test_prep[glm_num_features_glm].copy()

