def add_frequency_features_local(data, cols):
    out = data.copy()
    for c in cols:
        if c in out.columns:
            freq = (
                out[c]
                .fillna("")
                .astype(str)
                .str.strip()
                .str.upper()
                .value_counts(normalize=True)
            )
            out[f"{c}__freq_fal_post"] = (
                out[c]
                .fillna("")
                .astype(str)
                .str.strip()
                .str.upper()
                .map(freq)
                .fillna(0)
            )
            out[f"{c}__rare_fal_post"] = 1 - out[f"{c}__freq_fal_post"]
    return out

