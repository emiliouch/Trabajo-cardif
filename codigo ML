print_section("10.11) TRAMOS OPERATIVOS PROPUESTOS")

p99 = prod_df["score_prod"].quantile(0.99)
p95 = prod_df["score_prod"].quantile(0.95)
p90 = prod_df["score_prod"].quantile(0.90)

prod_df["nivel_riesgo_prod"] = np.select(
