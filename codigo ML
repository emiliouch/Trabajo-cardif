print("Tasa y_rule:", round(df["y_rule"].mean(), 4))
print("Proporción post AGO-2024:", round(df["is_post"].mean(), 4))

# -----------------------------
# 3) Clusters operativos
# -----------------------------
print_section("3) CLUSTERS OPERATIVOS")

cluster_cols = ["COMUNA_PER", "CANAL_VENTA_SEG", "AGRUPACION_QS", "MEDIO_PAGO_SEG", "FRECUENCIA_PAGO"]
for c in cluster_cols:
    safe_upper_col(df, c)

# Definición de clusters operativos
df["cluster_comuna_canal"] = (
    df["COMUNA_PER"] + "|" + df["CANAL_VENTA_SEG"]
    if {"COMUNA_PER", "CANAL_VENTA_SEG"}.issubset(df.columns)
    else ""
)
df["cluster_comuna_qs"] = (
    df["COMUNA_PER"] + "|" + df["AGRUPACION_QS"]
    if {"COMUNA_PER", "AGRUPACION_QS"}.issubset(df.columns)
    else ""
)
df["cluster_pago_freq"] = (
    df["MEDIO_PAGO_SEG"] + "|" + df["FRECUENCIA_PAGO"]
    if {"MEDIO_PAGO_SEG", "FRECUENCIA_PAGO"}.issubset(df.columns)
    else ""
)
df["cluster_comuna_pago"] = (
    df["COMUNA_PER"] + "|" + df["MEDIO_PAGO_SEG"]
    if {"COMUNA_PER", "MEDIO_PAGO_SEG"}.issubset(df.columns)
    else ""
)

cluster_list = ["cluster_comuna_canal", "cluster_comuna_qs", "cluster_pago_freq", "cluster_comuna_pago"]
cluster_tables = {}

for col in cluster_list:
    cluster_tables[col] = cluster_summary(df, col, id_col_=id_col, min_size=15, top_n=30)
    print(f"\n=== {col} ===")
    display(cluster_tables[col].head(20))
    cluster_tables[col].to_csv(os.path.join(OUT_DIR, f"{col}_summary.csv"), index=False)

for col in cluster_list:
    top_df = cluster_tables[col].head(15).copy()
    if not top_df.empty:
        plt.figure(figsize=(10, 6))
        sns.barplot(data=top_df, y=col, x="n_post")
