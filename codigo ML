# === A1.1) Ranking de clusters que explotan post-AGO2024 ===

def cluster_summary(df, cluster_col, min_size=20, top_n=25):
    tmp = df[df[cluster_col].ne("")].copy()
    if tmp.empty:
        return pd.DataFrame()

    overall_post_rate = tmp["is_post"].mean()

    g = (tmp.groupby(cluster_col, dropna=False)
           .agg(n_total=(id_col,"count"),
                n_post=("is_post","sum"),
                n_pre=("is_post", lambda x: (x==0).sum()),
                y_rate=("y_rule","mean"),
                post_rate=("is_post","mean"),
                evasion=("FLAG_EVASION_AMBOS","mean") if "FLAG_EVASION_AMBOS" in tmp.columns else ("y_rule","mean"),
                multiseg=("FLAG_MULTI_SEGURO","mean") if "FLAG_MULTI_SEGURO" in tmp.columns else ("y_rule","mean"))
           .reset_index())

    g = g[g["n_total"] >= min_size].copy()
    g["lift_post_vs_overall"] = g["post_rate"] / (overall_post_rate if overall_post_rate>0 else 1e-9)
    g = g.sort_values(["n_post","lift_post_vs_overall"], ascending=False).head(top_n)
    return g

for col in ["cluster_addr","cluster_ops","cluster_pay"]:
    print("\n====", col, "====")
    display(cluster_summary(df, col, min_size=20, top_n=20))


### Cómo leer esto (muy literal)
- `n_post` alto = ese cluster aporta muchos casos post quiebre.
- `lift_post_vs_overall` > 1 = ese cluster está **más cargado a post** que el promedio.
- `y_rate` alto = coincide con tu proxy de fraude.
- `evasion` alto = sugiere que ese cluster está “jugando” con umbrales.



# === A2) Clusters de red (requiere networkx). Si no lo tienes, te lo salta. ===
try:
    import networkx as nx

    rut_col = "RUT_JOIN" if "RUT_JOIN" in df.columns else None
    if rut_col is None:
        raise ValueError("No existe RUT_JOIN en el dataset.")

    # atributos para conectar (ajusta: mientras más, más conexiones)
    attr_cols = [c for c in ["cluster_addr","COMUNA_PER","CANAL_VENTA_SEG","SUCURSAL_VENTA_SEG","MEDIO_PAGO_SEG","GLOSA_GIRO_PER"]
                 if c in df.columns]

    G = nx.Graph()

    # limitar a atributos “informativos” (evita conectar a todo el mundo por valores gigantes)
    # ejemplo: excluir categorías con freq > 20% del dataset
    max_freq = 0.20
    allowed_values = {}
    for c in attr_cols:
        vc = df[c].value_counts(dropna=False)
        allowed = set(vc[vc/len(df) <= max_freq].index.tolist())
        allowed_values[c] = allowed

    # construir grafo
    for _, row in df[[rut_col] + attr_cols].iterrows():
        rut = row[rut_col]
        if not rut or rut == "": 
            continue
        rut_node = f"RUT:{rut}"
        G.add_node(rut_node, kind="rut")

        for c in attr_cols:
            val = row[c]
            if not val or val == "":
                continue
            if val not in allowed_values[c]:
                continue
            attr_node = f"{c}:{val}"
            G.add_node(attr_node, kind="attr", attr=c)
            G.add_edge(rut_node, attr_node)

    # componentes conectados sobre subgrafo de ruts
    # (componentes del grafo completo; luego extraemos ruts)
    comps = list(nx.connected_components(G))
    rut_components = []
    for comp in comps:
        ruts = [n for n in comp if n.startswith("RUT:")]
        if len(ruts) >= 3:  # umbral mínimo
            rut_components.append(ruts)

    # asignar id de componente a cada RUT
    rut_to_comp = {}
    for i, ruts in enumerate(rut_components):
        for r in ruts:
            rut_to_comp[r.replace("RUT:","")] = i

    df["cluster_net"] = df[rut_col].map(rut_to_comp).fillna(-1).astype(int)

    net_stats = (df[df["cluster_net"]!=-1]
                 .groupby("cluster_net")
                 .agg(n=(id_col,"count"),
                      n_ruts=(rut_col,"nunique"),
                      post_rate=("is_post","mean"),
                      y_rate=("y_rule","mean"),
                      evasion=("FLAG_EVASION_AMBOS","mean") if "FLAG_EVASION_AMBOS" in df.columns else ("y_rule","mean"))
                 .reset_index()
                 .sort_values(["n","post_rate"], ascending=False)
                 .head(20))

    display(net_stats)

except Exception as e:
    print("No se pudo ejecutar cluster de red (networkx no disponible o error):", str(e))



### Lectura de cluster_net
- `n_ruts` grande y `post_rate` alto: red conectada por atributos que explota post quiebre.
- Esto es MUY útil para decir “hay estructura de red” aunque no tengas parentesco.

  


# === A3) KMeans clustering (sklearn) ===
from sklearn.preprocessing import StandardScaler
from sklearn.cluster import KMeans
