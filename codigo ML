def add_suspicion_features(data):
    out = data.copy()

    # Numéricos
    for c in [
        "DIF_VIGENCIA", "USO_TOPE", "COUNT_OF_NUMERO_FINAL", "CUENTA_SIN_FAMILIAR_AUX",
        "N_SEG_12M_PRE_OCURR", "N_SIN_OTRAS_COB", "MONTO_FINAL_UF", "EDAD_AL_SINIESTRO"
    ]:
        if c in out.columns:
            out[c] = pd.to_numeric(out[c], errors="coerce")

    # Categóricas relevantes
    for c in [
        "COMUNA_PER", "CANAL_VENTA_SEG", "SUCURSAL_VENTA_SEG", "MEDIO_PAGO_SEG",
        "FRECUENCIA_PAGO", "PLAN_AUX", "COB", "GLOSA_GIRO_PER",
