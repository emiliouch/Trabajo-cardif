    "FLAG_SIN_CRUZADA",
    "FLAG_EVASION_DIF31_45",
    "FLAG_EVASION_TOPE_75_80"
] if c in df.columns]

cat_features = [c for c in [
    "COMUNA_PER",
    "CANAL_VENTA_SEG",
    "SUCURSAL_VENTA_SEG",
    "MEDIO_PAGO_SEG",
    "COB",
    "PLAN_AUX",
    "AGRUPACION_QS",
    "GLOSA_GIRO_PER",
    "TRAMO_DIF_VIG",
    "TRAMO_USO_TOPE",
    "TRAMO_EDAD"
] if c in df.columns]

model_features = num_features + cat_features

print("Numéricas:", num_features)
print("Categóricas:", cat_features)






train = df[df["is_post"] == 0].copy()
test = df[df["is_post"] == 1].copy()

print("Train shape:", train.shape)
print("Test shape :", test.shape)
print("Target train:", round(train["y_rule"].mean(), 4))
print("Target test :", round(test["y_rule"].mean(), 4))





X_train = train[model_features].copy()
X_test = test[model_features].copy()

y_train = train["y_rule"].astype(int)
y_test = test["y_rule"].astype(int)





numeric_transformer = Pipeline(steps=[
    ("imputer", SimpleImputer(strategy="median"))
])

categorical_transformer = Pipeline(steps=[
    ("imputer", SimpleImputer(strategy="constant", fill_value="MISSING")),
    ("encoder", OrdinalEncoder(handle_unknown="use_encoded_value", unknown_value=-1))
])

preprocessor = ColumnTransformer(
    transformers=[
        ("num", numeric_transformer, num_features),
        ("cat", categorical_transformer, cat_features)
    ],
    remainder="drop"
)

hgb_model = HistGradientBoostingClassifier(
    learning_rate=0.03,
    max_iter=500,
    max_depth=6,
    min_samples_leaf=30,
    l2_regularization=1.0,
    random_state=RANDOM_STATE
)

clf = Pipeline(steps=[
    ("preprocessor", preprocessor),
    ("model", hgb_model)
])

clf.fit(X_train, y_train)

train["risk_hgb"] = clf.predict_proba(X_train)[:, 1]
test["risk_hgb"] = clf.predict_proba(X_test)[:, 1]

print("HGB AUC train:", round(roc_auc_score(y_train, train["risk_hgb"]), 4))
print("HGB AUC test :", round(roc_auc_score(y_test, test["risk_hgb"]), 4))
print("HGB PR-AUC train:", round(average_precision_score(y_train, train["risk_hgb"]), 4))
print("HGB PR-AUC test :", round(average_precision_score(y_test, test["risk_hgb"]), 4))

def precision_at_k(y_true, scores, k):
    idx = np.argsort(scores)[::-1][:k]
    return y_true.iloc[idx].mean()

for k in [50, 100, 200, 500]:
    if k <= len(test):
        print(f"HGB Precision@{k}: {precision_at_k(test['y_rule'], test['risk_hgb'], k):.3f}")


perm = permutation_importance(
    clf,
    X_test,
    y_test,
    n_repeats=10,
    random_state=RANDOM_STATE,
    scoring="average_precision"
)

feature_names = model_features

perm_df = pd.DataFrame({
    "feature": feature_names,
    "importance_mean": perm.importances_mean,
    "importance_std": perm.importances_std
}).sort_values("importance_mean", ascending=False)

perm_df.head(20)



