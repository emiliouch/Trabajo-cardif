def collapse_rare_categories_hyb_glm(train_df, test_df, cols, top_n=5):
    train_out = train_df.copy()
    test_out = test_df.copy()

    for c in cols:
        if c not in train_out.columns:
            continue

        train_out[c] = train_out[c].fillna("MISSING").astype(str).str.strip().str.upper()
        test_out[c] = test_out[c].fillna("MISSING").astype(str).str.strip().str.upper()

        top_levels = train_out[c].value_counts().head(top_n).index.tolist()

        train_out[c] = np.where(train_out[c].isin(top_levels), train_out[c], "OTROS")
        test_out[c] = np.where(test_out[c].isin(top_levels), test_out[c], "OTROS")

    return train_out, test_out

