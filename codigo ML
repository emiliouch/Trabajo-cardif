def build_if_matrix(df_fit, df_apply, num_cols, cat_cols):
    X_num = df_apply[num_cols].copy()

    for c in num_cols:
        X_num[c] = pd.to_numeric(X_num[c], errors="coerce")
        med = pd.to_numeric(df_fit[c], errors="coerce").median()
        X_num[c] = X_num[c].fillna(med)

    X_cat = pd.DataFrame(index=df_apply.index)

    for c in cat_cols:
        freq_map = (
            df_fit[c]
            .fillna("")
            .astype(str)
            .str.strip()
            .str.upper()
            .value_counts(normalize=True)
        )
        X_cat[c + "__freq"] = (
            df_apply[c]
            .fillna("")
            .astype(str)
            .str.strip()
            .str.upper()
            .map(freq_map)
            .fillna(0)
        )

    X_all = pd.concat([X_num, X_cat], axis=1)
    return X_all

X_pre_if = build_if_matrix(pre_df, pre_df, iso_num_features, iso_cat_features)
X_post_if = build_if_matrix(pre_df, post_df, iso_num_features, iso_cat_features)
X_all_if = build_if_matrix(pre_df, df, iso_num_features, iso_cat_features)

scaler_if = StandardScaler()
X_pre_if_s = scaler_if.fit_transform(X_pre_if)
X_post_if_s = scaler_if.transform(X_post_if)
X_all_if_s = scaler_if.transform(X_all_if)

iso_break = IsolationForest(
    n_estimators=400,
    contamination="auto",
    random_state=RANDOM_STATE,
    n_jobs=-1
)
iso_break.fit(X_pre_if_s)

pre_df["risk_iso_break"] = -iso_break.score_samples(X_pre_if_s)
post_df["risk_iso_break"] = -iso_break.score_samples(X_post_if_s)
df["risk_iso_break"] = -iso_break.score_samples(X_all_if_s)

print("\n=== ISOLATION FOREST DEL QUIEBRE ===")
print("Risk mean PRE :", round(pre_df["risk_iso_break"].mean(), 4))
print("Risk mean POST:", round(post_df["risk_iso_break"].mean(), 4))

# Umbral de anomalía usando el percentil 95 del período PRE
iso_threshold = pre_df["risk_iso_break"].quantile(0.95)
df["flag_anom_break"] = (df["risk_iso_break"] >= iso_threshold).astype(int)

print("Threshold anomalía (p95 PRE):", round(iso_threshold, 4))
print("Anomaly rate PRE :", round(pre_df.assign(flag=(pre_df['risk_iso_break'] >= iso_threshold).astype(int))['flag'].mean(), 4))
print("Anomaly rate POST:", round(post_df.assign(flag=(post_df['risk_iso_break'] >= iso_threshold).astype(int))['flag'].mean(), 4))

