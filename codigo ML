    "FLAG_FIN_SEMANA","EDAD_AL_SINIESTRO"
] if c in df.columns]

# Categóricas: usamos frequency encoding para no explotar dimensionalidad
cat_features = [c for c in [
    "COMUNA_PER","CANAL_VENTA_SEG","SUCURSAL_VENTA_SEG","MEDIO_PAGO_SEG",
    "COB","PLAN_AUX","AGRUPACION_QS","GLOSA_GIRO_PER",
    "TRAMO_DIF_VIG","TRAMO_USO_TOPE","TRAMO_EDAD"
] if c in df.columns]

X_num = df[numeric_features].copy() if numeric_features else pd.DataFrame(index=df.index)
X_num = X_num.replace([np.inf, -np.inf], np.nan)
for c in X_num.columns:
    X_num[c] = X_num[c].fillna(X_num[c].median())

X_cat = pd.DataFrame(index=df.index)
for c in cat_features:
    vc = df[c].fillna("").value_counts(dropna=False)
    X_cat[c + "__freq"] = df[c].fillna("").map(vc) / len(df)

X = pd.concat([X_num, X_cat], axis=1)

scaler = StandardScaler()
X_scaled = scaler.fit_transform(X)

ks = [3,4,5,6,8,10]
scores = []
for k in ks:
    km = KMeans(n_clusters=k, random_state=RANDOM_STATE, n_init="auto")
    labels = km.fit_predict(X_scaled)
    scores.append((k, silhouette_score(X_scaled, labels)))

scores_df = pd.DataFrame(scores, columns=["k","silhouette"]).sort_values("silhouette", ascending=False)
display(scores_df)

best_k = int(scores_df.iloc[0]["k"])
km = KMeans(n_clusters=best_k, random_state=RANDOM_STATE, n_init="auto")
df["cluster_ml"] = km.fit_predict(X_scaled)

