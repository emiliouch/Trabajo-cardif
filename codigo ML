    med = glm_train_prep[c].median()
    glm_train_prep[c] = glm_train_prep[c].fillna(med)
    glm_test_prep[c] = glm_test_prep[c].fillna(med)

# colapsar categorías raras
glm_train_prep, glm_test_prep = collapse_rare_categories(
    glm_train_prep, glm_test_prep, glm_cat_features, top_n=10
)

# interacción explícita
