] if c in df.columns]

X_train_iso = train[iso_features].copy()
X_test_iso = test[iso_features].copy()

for c in iso_features:
    X_train_iso[c] = pd.to_numeric(X_train_iso[c], errors="coerce")
    X_test_iso[c] = pd.to_numeric(X_test_iso[c], errors="coerce")
    X_train_iso[c] = X_train_iso[c].fillna(X_train_iso[c].median())
    X_test_iso[c] = X_test_iso[c].fillna(X_train_iso[c].median())





scaler = StandardScaler()
X_train_iso_s = scaler.fit_transform(X_train_iso)
X_test_iso_s = scaler.transform(X_test_iso)

iso_model = IsolationForest(
    n_estimators=400,
    contamination="auto",
    random_state=RANDOM_STATE,
    n_jobs=-1
)
iso_model.fit(X_train_iso_s)

train["risk_iso"] = -iso_model.score_samples(X_train_iso_s)
test["risk_iso"] = -iso_model.score_samples(X_test_iso_s)




print("Promedio score ISO por clase - Train")
display(train.groupby("y_rule")["risk_iso"].agg(["mean", "median", "std", "count"]))

print("Promedio score ISO por clase - Test")
display(test.groupby("y_rule")["risk_iso"].agg(["mean", "median", "std", "count"]))




for k in [50, 100, 200, 500]:
    if k <= len(test):
        print(f"IsolationForest Precision@{k}: {precision_at_k(test['y_rule'], test['risk_iso'], k):.3f}")




## Score final combinado

Se combina el score supervisado y el score no supervisado para priorizar casos que sean:
- similares al patrón históricamente sospechoso
- y además anómalos respecto al comportamiento general



def zscore(s):
    return (s - s.mean()) / s.std()

test["risk_cat_z"] = zscore(test["risk_cat"])
test["risk_iso_z"] = zscore(test["risk_iso"])

test["risk_final"] = 0.7 * test["risk_cat_z"] + 0.3 * test["risk_iso_z"]




for k in [50, 100, 200, 500]:
    if k <= len(test):
        print(f"Score combinado Precision@{k}: {precision_at_k(test['y_rule'], test['risk_final'], k):.3f}")





