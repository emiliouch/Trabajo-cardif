        (count(t1.NUMERO_FINAL)) AS COUNT_of_NUMERO_FINAL
FROM WORK.DW_SINIESTROS_AUX2 t1
GROUP BY t1.RUT_FINAL;
QUIT;

PROC SQL;
CREATE TABLE WORK.DW_SINIESTROS_AUX6 AS
SELECT DISTINCT t1.RUT_FINAL,
       T2.RUT_RELACIONADO,
       T3.NUMERO_FINAL
FROM WORK.DW_SINIESTROS_AUX2 t1
LEFT JOIN CLSNCPOP.DW_PER_RELACION T2 ON T1.RUT_FINAL=T2.RUT_PRINCIPAL
LEFT JOIN WORK.DW_SINIESTROS_AUX2 T3 ON T2.RUT_RELACIONADO = T3.RUT_FINAL
