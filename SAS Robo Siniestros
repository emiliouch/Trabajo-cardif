PROC SQL;
CREATE TABLE WORK.DW_SINIESTROS_AUX7 AS
SELECT t1.RUT_FINAL,
       COUNT(t1.NUMERO_FINAL) AS CUENTA_SIN_FAMILIAR
FROM WORK.DW_SINIESTROS_AUX6 t1
GROUP BY t1.RUT_FINAL;
QUIT;

PROC SQL;
CREATE TABLE WORK.DW_SINIESTROS_AUX8 AS
SELECT  t1.*,
        t2.SUM_of_MONTO_PESOS,
        CASE WHEN t2.MIN_of_FEC_PAGO = . THEN t1.MES_ESTADO ELSE datepart(t2.MIN_of_FEC_PAGO) END FORMAT=DDMMYY10. AS FEC_PAGO,
        t2.MIN_of_FEC_PAGO,
        t3.RIESGODSC,
        t4.COUNT_of_NUMERO_FINAL,
        CASE WHEN t5. CUENTA_SIN_FAMILIAR =. THEN 0 ELSE t5.CUENTA_SIN_FAMILIAR END AS CUENTA_SIN_FAMILIAR_AUX, t6.EstadoFraude,
        t6.Resultado1,
        t6.FecResultado1,
        t6.Resultado2,
        t6.FecResultado2,
        t7.RUT_FINAL AS RUT_ALERTADO
FROM WORK.DW_SINIESTROS_AUX2 t1
LEFT JOIN WORK.DW_SINIESTROS_AUX4 t2 ON T1.ID=T2.ID
LEFT JOIN LIB1.ACT_RIESGO t3 ON T1.RIESGO_OPERACIONES_FINAL = T3.RIESGOOPERACIONES
LEFT JOIN WORK.DW_SINIESTROS_AUX5 t4 ON T1.RUT_FINAL=t4.RUT_FINAL
LEFT JOIN WORK.DW_SINIESTROS_AUX7 t5 ON T1.RUT_FINAL=t5.RUT_FINAL
LEFT JOIN WORK.'Investigaciones Robo'n t6 ON t6.NumeroSiniestro = t1.NUMERO_FINAL
LEFT JOIN WORK.RUT_SOSPECHOSOS_DICTAMEN_APROB t7 ON T1.RUT_FINAL=T7.RUT_FINAL;
