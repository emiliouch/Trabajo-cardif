proc sql;
    create table Pagados as
    select  t1.numero,
            t1.rutasegurado,
            t1.dvasegurado,
            t1.poliza,
            t1.riesgoactuarial,
            t1.riesgooperaciones,
            t1.detalleresolucion,
            t1.agrupaciondetalleresolucion,
            t1.socioactuarial,
            t2.Fec_Otorgamiento,
            t2.Fec_Ocurre,
            t2.Fec_Nacimiento,
            t2.Min_Mes_Estado,
            t1.montobruto,
            t1.totalcuotas
    from base_aux_pagados_3 t1
    left join base_madre_2 t2
        on (t1.numero = t2.numero);
quit;

