** Paso 0: Base Madre;

proc sql;
    create table base_madrePag as
    select  numero,
            rutasegurado,
            dvasegurado,
            estadocuota,
            poliza,
            riesgoactuarial,
            riesgooperaciones,
            detalleresolucion,
            agrupaciondetalleresolucion,
            socioactuarial,
            intnx('month',datepart(fechaocurrencia),0,'s')
                format=ddmmyy10. as Fec_Ocurre,
            intnx('month',datepart(fechaotorgamiento),0,'s')
                format=ddmmyy10. as Fec_Otorgamiento,
            intnx('month',datepart(aseguradofechanac),0,'s')
                format=ddmmyy10. as Fec_Nacimiento,
            input(strip(estadomes),anydtdte7.0)
                format=ddmmyy10. as Mes_Estado,
            totalcuotas
                format=ddmmyy10. as totalcuotas,
            montobruto
                format=commax20.0 as montobruto
    from LIB1.ACT_BASE_SINIESTRO
    where estadocuota in ('PAGO TOTAL','PAGO PARCIAL','NUEVO PAGO',
                          'RECUPERO','PENDIENTE','PAGO FUTURO')
      and poliza IN (&FILTRO_BC_AUX)
      and input(strip(estadomes),anydtdte7.0) <= &Fec_Cierre.
      and FECHAOCURRENCIA >= '1Jan2020:0:0:0'dt
    group by numero,
             poliza,
             riesgoactuarial,
             riesgooperaciones,
             socioactuarial,
             Fec_Ocurre,
             Mes_Estado
    order by numero,
             Fec_Ocurre,
             Mes_Estado;
quit;

** Paso 0.1: Agrupamos por la minima fecha ocurrencia;

proc sql;
    create table base_madre_2 as
    select  numero,
            rutasegurado,
            dvasegurado,
            min(Fec_Otorgamiento) format=ddmmyy10. as Fec_Otorgamiento,
            min(Fec_Ocurre)       format=ddmmyy10. as Fec_Ocurre,
            min(Fec_Nacimiento)   format=ddmmyy10. as Fec_Nacimiento,
            min(Mes_Estado)       format=ddmmyy10. as Min_Mes_Estado
    from base_madrePag
    group by numero;
quit;

