PROC SQL;
CREATE TABLE Siniestros_Fin AS
SELECT  t1.NUMERO,
        t1.rutasegurado,
        t1.dvasegurado,
        t1.POLIZA,
        t1.RIESGOACTUARIAL,
        t1.riesgooperaciones,
        t1.detalleresolucion,
        t1.agrupaciondetalleresolucion,
        t1.SOCIOACTUARIAL,
        (MIN(t1.Fec_Otorgamiento)) FORMAT=DDMMYY10. AS MIN_of_Fec_Otorgamiento,
        (MIN(t1.Fec_Ocurre))       FORMAT=DDMMYY10. AS MIN_of_Fec_Ocurre,
        (MIN(t1.Fec_Nacimiento))   FORMAT=DDMMYY10. AS MIN_of_Fec_Nacimiento,
        (MIN(t1.Min_Mes_Estado))   FORMAT=DDMMYY10. AS MIN_of_Mes_Estado,
        (SUM(t1.montobruto))       FORMAT=COMMAX20. AS SUM_of_montobruto,
        (SUM(t1.totalcuotas))      FORMAT=COMMAX20. AS SUM_of_totalcuotas
FROM Siniestros_Control t1
GROUP BY t1.NUMERO,
         t1.rutasegurado,
         t1.dvasegurado,
         t1.POLIZA,
         t1.RIESGOACTUARIAL,
         t1.riesgooperaciones,
         t1.SOCIOACTUARIAL;
QUIT;

