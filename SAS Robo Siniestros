        (SUM(t1.MONTO_PESOS)) FORMAT=14.2 AS SUM_of_MONTO_PESOS,
        (MIN(t1.FEC_PAGO)) FORMAT=DATETIME22.3 AS MIN_of_FEC_PAGO
