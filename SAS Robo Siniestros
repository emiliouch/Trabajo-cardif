PROC SQL;
CREATE TABLE WORK.DW_SINIESTROS_AUX2 AS
SELECT  T1.*,
        T2.SUM_MONTO,
        T2.COD,
        T2.mes_estado,
        CASE WHEN T1.POLIZA_MADRE = '' THEN T2.POLIZA ELSE T1.POLIZA_MADRE END AS POLIZA_FINAL,
        CASE WHEN T1.RUT_ASEGURADO = '' THEN T2.RUT ELSE T1.RUT_ASEGURADO END AS RUT_FINAL,
        CASE WHEN T1.NUMERO_SIN = '' THEN T2.NUMERO ELSE T1.NUMERO_SIN END AS NUMERO_FINAL,
        CASE WHEN T1.FEC_INIC_VIG_SEGURO = . THEN T2.FEC_OTORGAMIENTO ELSE T1.FEC_INIC_VIG_SEGURO END format=ddmmyy10. AS FEC_OTORGAMIENTO_FINAL,
        CASE WHEN T1.FEC_OCURRENCIA = . THEN T2.FEC_OCURRE ELSE T1.FEC_OCURRENCIA END format=ddmmyy10. AS FEC_OCURRENCIA_FINAL,
        CASE WHEN T1.COD_COB_CHIPSY = '' THEN T2.RIESGOOPERACIONES ELSE T1.COD_COB_CHIPSY END AS RIESGO_OPERACIONES_FINAL,
        CASE WHEN T1.COD_COB_ACTUARIAL = '' THEN T2.RIESGOACTUARIAL ELSE T1.COD_COB_ACTUARIAL END AS RIESGO_ACTUARIAL_FINAL,
        CASE WHEN T1.CAUSA = '' THEN T2.AGRUPACIONDETALLERESOLUCION ELSE T1.CAUSA END AS CAUSA_FINAL,
        CASE WHEN T1.CAUSA_DETALLE = '' THEN T2.DETALLERESOLUCION ELSE T1.CAUSA_DETALLE END AS CAUSA_DETALLE_FINAL
FROM WORK.DW_SINIESTROS_AUX1 T1
FULL OUTER JOIN WORK.AGRUPADOS T2 ON T1.NUMERO_SIN = T2.NUMERO;
QUIT;

PROC SQL;
CREATE TABLE WORK.DW_SINIESTROS_AUX3 AS
