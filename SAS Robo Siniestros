ELSE IF find(RIESGOSDSC,'CAJEROS') OR find(RIESGOSDSC,'C.A') THEN COB='ROBO DINERO VENTANILLA';
ELSE COB=RIESGOSDSC;

IF POLIZA_FINAL='121057429' AND PLAN_AUX = 'PLAN 1' AND COB = 'COMPRA PROTEGIDA X ROBO' THEN TOPE = 15;
